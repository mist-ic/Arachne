# =============================================================================
# Arachne — Environment Variables
# =============================================================================
# Copy to .env and modify as needed:
#   cp .env.example .env
# =============================================================================

# ----- PostgreSQL (Arachne data) -----
POSTGRES_USER=arachne
POSTGRES_PASSWORD=arachne
POSTGRES_DB=arachne
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ----- PostgreSQL (Temporal) -----
TEMPORAL_POSTGRES_USER=temporal
TEMPORAL_POSTGRES_PASSWORD=temporal
TEMPORAL_POSTGRES_DB=temporal
TEMPORAL_POSTGRES_PORT=5433

# ----- MinIO -----
MINIO_ROOT_USER=arachne
MINIO_ROOT_PASSWORD=arachne123
MINIO_ENDPOINT=localhost:9000

# ----- Redpanda -----
REDPANDA_BROKERS=localhost:19092
REDPANDA_SCHEMA_REGISTRY=http://localhost:18081

# ----- Temporal -----
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_TASK_QUEUE=scrape-http

# ----- Application -----
ARACHNE_LOG_LEVEL=INFO
ARACHNE_API_PORT=8000

# ----- AI Extraction -----
# Google Gemini API key (primary cloud model for extraction)
GEMINI_API_KEY=

# OpenAI API key (optional — enables GPT-4o extraction)
# OPENAI_API_KEY=

# Anthropic API key (optional — enables Claude extraction)
# ANTHROPIC_API_KEY=

# Extraction routing mode: minimize | balanced | accuracy
ARACHNE_COST_MODE=balanced

# Default LLM model (LiteLLM format)
ARACHNE_DEFAULT_MODEL=gemini/gemini-2.5-flash

# Per-page cost ceiling (USD) — prevents runaway spending during cascade
ARACHNE_MAX_COST_PER_PAGE_USD=0.10

# ----- Ollama (Local Models) -----
# Ollama API endpoint (set to http://localhost:11434 for local dev)
ARACHNE_OLLAMA_BASE_URL=http://ollama:11434

# ----- CAPTCHA Solving (Optional) -----
# 2Captcha API key for external CAPTCHA solving
# ARACHNE_CAPTCHA_2CAPTCHA_KEY=

# CapSolver API key for external CAPTCHA solving
# ARACHNE_CAPTCHA_CAPSOLVER_KEY=
