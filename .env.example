# =============================================================================
# Arachne — Environment Variables
# =============================================================================
# Copy to .env and modify as needed:
#   cp .env.example .env
# =============================================================================

# ----- PostgreSQL (Arachne data) -----
POSTGRES_USER=arachne
POSTGRES_PASSWORD=arachne
POSTGRES_DB=arachne
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ----- PostgreSQL (Temporal) -----
TEMPORAL_POSTGRES_USER=temporal
TEMPORAL_POSTGRES_PASSWORD=temporal
TEMPORAL_POSTGRES_DB=temporal
TEMPORAL_POSTGRES_PORT=5433

# ----- MinIO -----
MINIO_ROOT_USER=arachne
MINIO_ROOT_PASSWORD=arachne123
MINIO_ENDPOINT=localhost:9000

# ----- Redpanda -----
REDPANDA_BROKERS=localhost:19092
REDPANDA_SCHEMA_REGISTRY=http://localhost:18081

# ----- Temporal -----
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_TASK_QUEUE=scrape-http

# ----- Application -----
ARACHNE_LOG_LEVEL=INFO
ARACHNE_API_PORT=8000
